          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h1 id=\"findings\">Findings</h1>\n<span class=\"paragraph\">The trigram model has the lowest loss on dev when there is zero weight on regularisation. </span>\n<span class=\"paragraph\">I also found that a large learning rate and a large regularisation weight leads to gradient explosion because the derivative of the regularisation expression shows up in the gradient and can lead to enormous steps. </span></span>"
          }
        }
